{
  "name": "md-editor",
  "version": "0.2.5",
  "private": true,
  "description": "Daily-usable Markdown and MDX-compatible desktop editor.",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "pnpm --filter @md-editor/desktop dev",
    "tauri": "pnpm --filter @md-editor/desktop tauri",
    "build:macos": "pnpm --filter @md-editor/desktop tauri build --bundles dmg",
    "release": "node scripts/release/publish-desktop.mjs",
    "release:version": "node scripts/release/version-desktop.mjs",
    "smoke:editor-core": "node --experimental-strip-types scripts/smoke-editor-core.mjs",
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm -r --sort typecheck",
    "test": "pnpm -r --sort test",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "lint": "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml -- --check && cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml --all-targets -- -D warnings"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "catalog:",
    "@milkdown/kit": "catalog:",
    "@milkdown/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@uiw/react-codemirror": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
