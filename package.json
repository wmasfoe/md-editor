{
  "name": "md-editor",
  "version": "0.3.19",
  "private": true,
  "description": "Daily-usable Markdown and MDX-compatible desktop editor.",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "pnpm --filter @md-editor/desktop dev",
    "dev:site": "pnpm --filter @md-editor/site dev",
    "tauri": "pnpm --filter @md-editor/desktop tauri",
    "build:site": "pnpm --filter @md-editor/site build",
    "deploy:site": "node scripts/site/deploy-site.mjs",
    "build:macos": "pnpm --filter @md-editor/desktop tauri build --bundles dmg",
    "build:macos:release": "pnpm run build:macos:release:dmg && pnpm run build:macos:release:updater",
    "build:macos:release:dmg": "pnpm --filter @md-editor/desktop tauri build --bundles dmg --config src-tauri/tauri.release.conf.json",
    "build:macos:release:updater": "pnpm --filter @md-editor/desktop tauri build --bundles app --config src-tauri/tauri.release.conf.json",
    "release": "node scripts/release/publish-desktop.mjs",
    "release:version": "node scripts/release/version-desktop.mjs",
    "smoke:editor-core": "node --experimental-strip-types scripts/smoke-editor-core.mjs",
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm -r --sort typecheck",
    "test": "pnpm -r --sort test && pnpm test:release",
    "test:release": "node --test scripts/release/*.test.mjs",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "lint": "pnpm lint:oxlint && pnpm format:prettier:check && pnpm lint:rust",
    "lint:fix": "oxlint --fix . && prettier --write . && cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "lint:oxlint": "oxlint --deny-warnings .",
    "lint:rust": "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml -- --check && cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml --all-targets -- -D warnings",
    "format": "prettier --write . && cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "format:check": "pnpm format:prettier:check && cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml -- --check",
    "format:prettier:check": "prettier --check ."
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "catalog:",
    "@milkdown/kit": "catalog:",
    "@milkdown/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@uiw/react-codemirror": "catalog:",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
