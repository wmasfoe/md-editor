{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdown Editor",
  "version": "0.3.18",
  "identifier": "dev.md-editor.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:7273",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Markdown Editor",
        "width": 1120,
        "height": 760,
        "minWidth": 760,
        "minHeight": 520,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 13
        }
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": []
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/llama-server"],
    "resources": {
      "binaries/llama-runtime-macos-arm64/*.dylib": "",
      "binaries/llama-runtime-macos-arm64/LICENSE.llama.cpp": "local-ai-runtime/LICENSE.llama.cpp"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2QUMyRTJFMkRDNDkxM0MKUldROGtjUXRMaTZzdHVyK3MxLzRyN3VTOFBSM2tmNTFPa2dLNm5yS2lrQ3BmcGttOSs4U2NFK0EK",
      "endpoints": [
        "https://raw.githubusercontent.com/wmasfoe/homebrew-tap/main/md-editor-latest.json"
      ]
    }
  }
}
